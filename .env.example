# =============================================================
# INFER Configuration
# =============================================================
# Multi-Agent Prediction Engine. We don't guess. We infer.
# Uses Azure OpenAI for LLM and embeddings
# Uses in-memory GraphRAG (no external database required)
# =============================================================

# ===== Azure OpenAI Configuration =====
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# ===== LLM Configuration =====
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://your-endpoint.openai.azure.com/openai/deployments/gpt-4.1
LLM_MODEL_NAME=gpt-4.1

# ===== Embedding Configuration =====
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ===== OASIS / CAMEL-AI Configuration =====
OPENAI_API_KEY=your-api-key
OPENAI_API_BASE_URL=https://your-endpoint.openai.azure.com/openai/deployments/gpt-4.1

# ===== Graph Storage =====
GRAPH_STORAGE_TYPE=memory
GRAPH_DATA_DIR=./data/graphs
